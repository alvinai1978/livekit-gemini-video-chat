# You may copy the same LiveKit/Gemini values from backend/.env here.
# The agent also tries to read ../backend/.env automatically for local development.

LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=YOUR_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=YOUR_LIVEKIT_API_SECRET

# Gemini API key from Google AI Studio.
# LiveKit's Google plugin expects GOOGLE_API_KEY.
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Must match backend/.env LIVEKIT_AGENT_NAME
LIVEKIT_AGENT_NAME=az-gemini-voice-assistant

# Gemini Live voice settings
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Puck
GEMINI_LIVE_TEMPERATURE=0.7
