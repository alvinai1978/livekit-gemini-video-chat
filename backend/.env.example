# LiveKit project credentials
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=YOUR_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=YOUR_LIVEKIT_API_SECRET

# Production frontend URL for CORS.
# Example: FRONTEND_ORIGIN=https://your-app.vercel.app
# For multiple domains, use: ALLOWED_ORIGINS=https://domain1.com,https://domain2.com
FRONTEND_ORIGIN=http://localhost:5173

# Google Gemini API key from Google AI Studio
# Backend text chat uses GEMINI_API_KEY.
# LiveKit's Google voice plugin uses GOOGLE_API_KEY.
# Use the same key for both during local development.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY

# Typed AI chat panel
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=700
GEMINI_TEMPERATURE=0.6
DEBUG_AI_ERRORS=false

# Voice AI agent dispatch target
# This must match agent/.env LIVEKIT_AGENT_NAME exactly.
LIVEKIT_AGENT_NAME=az-gemini-voice-assistant

# Gemini Live voice settings, read by the agent service.
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Puck
